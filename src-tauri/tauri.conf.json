{
  "productName": "ChronX Wallet",
  "version": "1.5.10",
  "identifier": "com.chronx.wallet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeBuildCommand": "trunk build",
    "beforeDevCommand": "trunk serve --port 8080"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "android": {
      "minSdkVersion": 24
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["chronx"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "ChronX Wallet",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
